<?xml version="1.0" encoding="utf-8"?>
<!--
    Framework resource overrides — universal AOSP defaults.
    
    =========================================================================
    ⚠️ IMPORTANT: Device-specific values go in config.env, NOT here!
    =========================================================================
    
    For your device-specific overlay config:
      1. Run ./setup.sh to get the Android 13 framework-res.apk
      2. Extract stock overlay APKs from your device:
           /system/product/overlay/framework-res__auto_generated_rro_product.apk
           /system/vendor/overlay/framework-res__auto_generated_rro_vendor.apk
      3. Decompile with apktool and compare values (see README for guide link)
      4. Put the product-specific values in a file at project root:
           stock_overlay.xml
         The build will automatically include it.
    
    For values controlled by config.env (UDFPS, AOD, brightness, etc.):
      Edit config.env → build.sh generates res/values/generated.xml
    
    For simple bool/integer/string overrides:
      Uncomment the corresponding OPTIONAL STOCK VALUES in config.env
-->
<resources>

    <!-- ============================================================
         DOZE / AOD (Universal AOSP service component)
         ============================================================ -->
    <string name="config_dozeComponent" translatable="false">
        com.android.systemui/com.android.systemui.doze.DozeService
    </string>

    <!-- ============================================================
         POWER / BATTERY (Universal default levels)
         ============================================================ -->
    <integer name="config_criticalBatteryWarningLevel">5</integer>
    <integer name="config_lowBatteryWarningLevel">15</integer>
    <integer name="config_lowBatteryCloseWarningBump">3</integer>

    <!-- ============================================================
         MULTIUSER
         ============================================================ -->
    <integer name="config_multiuserMaximumUsers">4</integer>

    <!-- ============================================================
         AUTO-BRIGHTNESS DEBOUNCE (AOSP defaults)
         ============================================================ -->
    <integer name="config_autoBrightnessBrighteningLightDebounce">2000</integer>
    <integer name="config_autoBrightnessDarkeningLightDebounce">6000</integer>
    <integer name="config_lightSensorWarmupTime">200</integer>

    <!-- ============================================================
         ⬇ PLACE YOUR EXTRACTED STOCK VALUES BELOW ⬇
         
         To extract your device-specific values:
         1. Follow the guide at the top of this file
         2. Extract values from your stock product overlay APK
         3. Place them here, or better: create stock_overlay.xml
         
         Common values to extract:
         - config_radio_access_family (e.g., "GSM|WCDMA|LTE|NR")
         - config_biometric_sensors (fingerprint sensor config)
         - config_mainBuiltInDisplayCutout (notch/cutout path)
         - skip_restoring_network_selection (Samsung RIL)
         - config_switch_phone_on_voice_reg_state_change
         - config_dozeUdfpsLongPressSensorType
         ============================================================ -->

</resources>
