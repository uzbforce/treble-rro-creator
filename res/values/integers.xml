<!--
    Device-specific integer arrays — EXTRACT FROM YOUR STOCK FIRMWARE.
    
    ⚠️ The auto-brightness curves below are PLACEHOLDER values only!
    
    These must be replaced with values from YOUR device's stock overlay APK:
      /system/product/overlay/framework-res__auto_generated_rro_product.apk
      /system/vendor/overlay/framework-res__auto_generated_rro_vendor.apk
    
    See the TrebleDroid overlay guide for extraction instructions:
    https://github.com/TrebleDroid/treble_experimentations/wiki/How-to-create-an-overlay%3F
    
    Alternatively, you can set these via config.env (see OPTIONAL STOCK VALUES):
      - AUTO_BRIGHTNESS_LEVELS
      - AUTO_BRIGHTNESS_BACKLIGHT_VALUES
      (and the hysteresis arrays)
-->
<resources>

    <!-- ============================================================
         AUTO-BRIGHTNESS MAPPING — PLACEHOLDER VALUES
         
         Replace these with values extracted from your stock product
         overlay APK using the TrebleDroid guide above.
         
         These placeholder values (for a generic device) will work but
         will not provide optimal auto-brightness behavior.
         ============================================================ -->

    <!-- ⬇ Add YOUR auto-brightness arrays below ⬇
         
         OPTION 1: Set them via config.env (recommended):
           AUTO_BRIGHTNESS_LEVELS="1 5 10 50 100 500 1000 ..."
           AUTO_BRIGHTNESS_BACKLIGHT_VALUES="5 15 30 60 ..."
         
         OPTION 2: Place them here (if not using config.env):
           <integer-array name="config_autoBrightnessLevels">
               <item>1</item>
               <item>5</item>
               ...
           </integer-array>
           <integer-array name="config_autoBrightnessLcdBacklightValues">
               <item>5</item>
               <item>15</item>
               ...
           </integer-array>
         
         ⚠️ DO NOT use both options — that causes duplicate resource errors!
         
         Extract your values from the stock product overlay APK:
           /system/product/overlay/framework-res__auto_generated_rro_product.apk
         
         See the TrebleDroid overlay guide:
         https://github.com/TrebleDroid/treble_experimentations/wiki/How-to-create-an-overlay%3F
    -->

</resources>
