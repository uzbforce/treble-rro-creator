# =============================================================================
# Treble Overlay — Device Configuration
# =============================================================================
# TEMPLATE — Edit for YOUR device, then run: ./build.sh
#
# 📖 Finding your values:
#   Manufacturer:     adb shell getprop ro.product.manufacturer
#   Model:            adb shell getprop ro.product.model
#   Device codename:  adb shell getprop ro.product.device
#
# Reference example: Samsung Galaxy A90 5G — see config.env.example
# =============================================================================

# ── Device identity ───────────────────────────────────────────────────────
# These three values are used to auto-generate overlay names and packages.
DEVICE_MANUFACTURER="<device_manufacturer>" # only lowercase letters
DEVICE_MODEL="<device_model>" # e.g SM-A908N
DEVICE_CODENAME="<device_codename>"

# ── Android version ───────────────────────────────────────────────────────
# COMPILE_SDK_VERSION: API level for aapt2 link (e.g., 35 for Android 15)
# ANDROID_VERSION:     Display version string (e.g., "15")
COMPILE_SDK_VERSION=35
ANDROID_VERSION="15"
MIN_SDK_VERSION=33
TARGET_SDK_VERSION=34

# ── Overlay Priority ──────────────────────────────────────────────────────
# Priority of the overlay. Higher values override lower ones.
OVERLAY_PRIORITY=628
OVERLAY_PRIORITY_SYSTEMUI=9999

# ── Display Calibration ───────────────────────────────────────────────────
# ROUNDED_CORNER_RADIUS: Corner curve in pixels (e.g., 100). Set 0 for sharp.
# STATUS_BAR_HEIGHT: Status bar height in pixels (e.g., 76).
# STATUS_BAR_HEIGHT_LANDSCAPE: Status bar landscape height in pixels (e.g., 24).
# STATUS_BAR_PADDING_START: Status bar start (left) padding in pixels (e.g., 76).
ROUNDED_CORNER_RADIUS=100
STATUS_BAR_HEIGHT=76
STATUS_BAR_HEIGHT_LANDSCAPE=24

# ── Fingerprint (UDFPS) ───────────────────────────────────────────────────
# Coordinates for the Under-Display Fingerprint Sensor.
# Find yours from your device tree, or extract overlay from custom rom, or figure out
HAS_UDFPS=false
UDFPS_X=540
UDFPS_Y=2145
UDFPS_RADIUS=114
HAS_SAMSUNG_FINGERPRINT=false

# ── HBM (High Brightness Mode) for UDFPS ─────────────────────────────────
# Optical UDFPS sensors need HBM to illuminate your finger through the display. Set to true just in case
HAS_HBM=false
BRIGHTNESS_EXTENDED_MAXIMUM=486

# ── Samsung Vendor Service Control ────────────────────────────────────────
HAS_SAMSUNG_FOD=false
HAS_SAMSUNG_VIBRATOR=false

# ── Light sensor type ─────────────────────────────────────────────────────
# adb shell dumpsys sensorservice | grep -i "Light Sensor"
LIGHT_SENSOR_TYPE="android.sensor.light"

# ── Refresh Rate ──────────────────────────────────────────────────────────
DEFAULT_REFRESH_RATE=60
PEAK_REFRESH_RATE=60

# ── Battery Info ──────────────────────────────────────────────────────────
BATTERY_CAPACITY=4500
BATTERY_TYPICAL_CAPACITY=4500

# ── Brightness (0-255) ────────────────────────────────────────────────────
BRIGHTNESS_DIM=15
BRIGHTNESS_DARK=3
BRIGHTNESS_DOZE=60
BRIGHTNESS_DEFAULT=128
BRIGHTNESS_MIN=0
BRIGHTNESS_MAX=255

# ── Feature Flags ─────────────────────────────────────────────────────────
HAS_AOD=false                # Always-On Display support
HAS_DOZE=false               # Doze (deep sleep with notifications)
DOZE_SUSPEND_UNSUPPORTED=false # Set true if hwcomposer crashes on DOZE_SUSPEND
HAS_5G=false                 # 5G NR support, may still need IMS and Treble fixes
HAS_VOLTE=false              # VoLTE / VoWiFi support, may still need IMS and Treble fixes
HAS_BURN_IN_PROTECTION=false # AMOLED burn-in prevention, useless
HAS_DOUBLE_TAP_WAKE=false    # Double-tap to wake gesture

# ── Vendor HAL flags ──────────────────────────────────────────────────────
HAS_VENDOR_FINGERPRINT_HAL=false
HAS_VENDOR_VIBRATOR_HAL=false

# ── Build Tools ───────────────────────────────────────────────────────────
PLATFORM_JAR="/usr/share/android-framework-res/framework-res.apk"
PLATFORM_KEY="keys/platform.pk8"
PLATFORM_CERT="keys/platform.x509.pem"
