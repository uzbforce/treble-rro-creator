# =============================================================================
# Treble Overlay — Device Configuration
# =============================================================================
# Edit this file to match YOUR device, then run: ./build.sh
#
# 📖 Finding your values:
#   Manufacturer:     adb shell getprop ro.product.manufacturer
#   Model:            adb shell getprop ro.product.model
#   Device codename:  adb shell getprop ro.product.device
#
# Reference example: Samsung Galaxy A90 5G — see config.env.example
# =============================================================================

# ── Device identity ───────────────────────────────────────────────────────
DEVICE_MANUFACTURER="<device_manufacturer>"
DEVICE_MODEL="<device_model>"
DEVICE_CODENAME="<device_codename>"

# ── Overlay Activation (Match) ────────────────────────────────────────────
# The overlay activates when this property matches this value.
# Default is ro.product.device. Some devices need ro.product.vendor.device.
DEVICE_PROP_NAME="ro.product.device"
DEVICE_PROP_VALUE="<device_codename>"

# ── Overlay Priority ──────────────────────────────────────────────────────
OVERLAY_PRIORITY=628
OVERLAY_PRIORITY_SYSTEMUI=9999

# ── Display Calibration ───────────────────────────────────────────────────
ROUNDED_CORNER_RADIUS=100
STATUS_BAR_HEIGHT=76
STATUS_BAR_HEIGHT_LANDSCAPE=24

# Notch / Display Cutout (SVG Path)
# Leave commented out if your device has no notch.
# Reference (Samsung Infinity-U):
#DISPLAY_CUTOUT="M-35.93,0C-29.26,0,-23.46,3.85,-22.46,9.56l.12.73a22.69,22.69,0,0,0,44.68,0l.12-.73C23.5,3.85,29.26,0,35.93,0Z @dp"

# ── Fingerprint (UDFPS) ───────────────────────────────────────────────────
HAS_UDFPS=false
UDFPS_X=540
UDFPS_Y=2145
UDFPS_RADIUS=114
HAS_SAMSUNG_FINGERPRINT=false

# ── HBM (High Brightness Mode) for UDFPS ─────────────────────────────────
HAS_HBM=false
BRIGHTNESS_EXTENDED_MAXIMUM=486

# ── Samsung Vendor Service Control ────────────────────────────────────────
HAS_SAMSUNG_FOD=false
HAS_SAMSUNG_VIBRATOR=false

# ── Light sensor type ─────────────────────────────────────────────────────
LIGHT_SENSOR_TYPE="android.sensor.light"

# ── Refresh Rate ──────────────────────────────────────────────────────────
DEFAULT_REFRESH_RATE=60
PEAK_REFRESH_RATE=60

# ── Battery Info ──────────────────────────────────────────────────────────
# ── Brightness (0-255) ────────────────────────────────────────────────────
BRIGHTNESS_DIM=15
BRIGHTNESS_DARK=3
BRIGHTNESS_DOZE=60
BRIGHTNESS_DEFAULT=128
BRIGHTNESS_MIN=0
BRIGHTNESS_MAX=255

# ── Feature Flags ─────────────────────────────────────────────────────────
HAS_AOD=false
HAS_DOZE=false
DOZE_SUSPEND_UNSUPPORTED=false
HAS_5G=false
HAS_VOLTE=false
HAS_BURN_IN_PROTECTION=false
HAS_DOUBLE_TAP_WAKE=false

# ── Vendor HAL flags ──────────────────────────────────────────────────────
HAS_VENDOR_FINGERPRINT_HAL=false
HAS_VENDOR_VIBRATOR_HAL=false

# ── Build Tools ───────────────────────────────────────────────────────────
PLATFORM_JAR="/usr/share/android-framework-res/framework-res.apk"
PLATFORM_KEY="keys/platform.pk8"
PLATFORM_CERT="keys/platform.x509.pem"

# ── Advanced Build Settings (DO NOT EDIT) ─────────────────────────────────
# The values below are for aapt2 dictionary compatibility (linking against 
# the Android 13 resource dictionary). 
#
# ⚠️ DO NOT CHANGE THESE to match your GSI version. 
# They are for build-time linking only and do NOT affect GSI compatibility.
# Changing them will likely cause "Resource not found" errors.
COMPILE_SDK_VERSION=35
ANDROID_VERSION="15"
MIN_SDK_VERSION=33
TARGET_SDK_VERSION=34

# ── Hardware Overlay Repo (Optional) ──────────────────────────────────────
# Use these to override matching logic ONLY for the hardware-overlay.zip.
# Useful for broad matching with ro.vendor.build.fingerprint globs.
#HW_OVERLAY_MATCH_PROP="ro.vendor.build.fingerprint"
#HW_OVERLAY_MATCH_VALUE="+*samsung/r3q*"

# ── OPTIONAL STOCK VALUES (Extract from your stock firmware) ────────────────
# Uncomment these and set values from your STOCK OVERLAY APKs.
# Extract them following the TrebleDroid guide:
#   https://github.com/TrebleDroid/treble_experimentations/wiki/How-to-create-an-overlay%3F
#
# ⚠️ These are OPTIONAL — the build works without them, but for best results
#    extract your device's actual values from the stock product overlay APK.
#    Only include values that DIFFER between product and vendor overlays!
# =============================================================================

# --- Radio / Telephony ---
#CONFIG_RADIO_ACCESS_FAMILY="GSM|WCDMA|LTE|NR"
#SKIP_RESTORING_NETWORK_SELECTION=true
#CONFIG_SWITCH_PHONE_ON_VOICE_REG_STATE_CHANGE=false

# --- Biometric / Fingerprint ---
#CONFIG_BIOMETRIC_SENSORS="0:2:15"  # sensorId:modality:strength (multi=semicolon)

# --- Display / Power ---
#CONFIG_FILL_MAIN_BUILTIN_DISPLAY_CUTOUT=true
#CONFIG_POWER_DECOUPLE_INTERACTIVE_MODE_FROM_DISPLAY=true
#CONFIG_POWER_DECOUPLE_AUTO_SUSPEND_MODE_FROM_DISPLAY=true
#CONFIG_DISPLAY_BLANKS_AFTER_DOZE=false
#CONFIG_DOZE_SUPPORTS_AOD_WALLPAPER=false

# --- Audio ---
#CONFIG_SUPPORT_AUDIO_SOURCE_UNPROCESSED=false
#CONFIG_CAMERA_SOUND_FORCED=false
#CONFIG_USE_DEV_INPUT_EVENT_FOR_AUDIO_JACK=true

# --- Connectivity ---
#CONFIG_WIFI_DISPLAY_SUPPORTS_PROTECTED_BUFFERS=true
#CONFIG_CARRIER_VOLTE_AVAILABLE=true
#CONFIG_CARRIER_VT_AVAILABLE=true
#CONFIG_CARRIER_WFC_IMS_AVAILABLE=true
#CONFIG_DYNAMIC_BIND_IMS=true
#CONFIG_FORCE_PHONE_GLOBALS_CREATION=true
#CONFIG_CARRIER_VOLTE_TTY_SUPPORTED=true

# --- Input ---
#CONFIG_CAMERA_DOUBLE_TAP_POWER_GESTURE_ENABLED=false

# --- Other Stock Values (Strings / Integers) ---
#CONFIG_DOZE_UDFPS_LONG_PRESS_SENSOR_TYPE="org.lineageos.sensor.udfps"

# --- Auto-brightness Arrays (space-separated values) ---
# Extract these from your stock product overlay APK!
#AUTO_BRIGHTNESS_LEVELS="1 5 10 50 100 500 1000 3000 5000 10000 20000 40000"
#AUTO_BRIGHTNESS_BACKLIGHT_VALUES="5 15 30 60 100 140 175 210 230 245 250 255"
